# Normalisation automatique des line endings
* text=auto eol=lf

# Fichiers explicitement texte (force LF même sous Windows)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf

# Binaires (jamais touchés)
*.png binary
*.jpg binary
*.jpeg binary
