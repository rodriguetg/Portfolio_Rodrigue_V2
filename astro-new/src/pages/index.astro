---
import '../styles/global.css';
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Rodrigue GBADOU — SEO, Automatisation, IA, Dev</title>
    <meta
      name="description"
      content="Portfolio de Rodrigue GBADOU — expert SEO, automatisation n8n, IA et développement web."
    />
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans antialiased">
    <main class="flex min-h-screen items-center justify-center p-8">
      <section class="max-w-2xl text-center animate-fade-in-up">
        <h1 class="font-heading text-4xl font-bold text-primary-400 md:text-5xl">
          Astro bootstrap OK
        </h1>
        <p class="mt-4 text-slate-300">
          Refonte Astro en cours. Cette page confirme que Tailwind v4, la police
          custom et l'animation sont chargées correctement.
        </p>
        <p class="mt-8 text-sm text-slate-500">
          Phase 0 · <span class="text-accent-purple">refonte-astro</span>
        </p>
      </section>
    </main>
  </body>
</html>
