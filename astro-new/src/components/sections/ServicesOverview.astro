---
import { services } from '../../data/services';
import { ArrowRight } from 'lucide-react';
---

<section
  id="services-overview"
  class="py-20 md:py-28"
  aria-labelledby="services-overview-title"
>
  <div class="container-custom">
    <div class="mx-auto max-w-2xl text-center mb-14">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-400 mb-3">
        4 pôles · 1 freelance
      </p>
      <h2
        id="services-overview-title"
        class="text-3xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-slate-100 to-slate-400 mb-4"
      >
        SEO/GEO, Automatisation, IA et Dev, sous le même toit
      </h2>
      <p class="text-base md:text-lg text-slate-400 leading-relaxed">
        Les frontières entre ces quatre domaines s'estompent. Un workflow n8n
        alimenté par un LLM qui publie sur un site Astro optimisé pour Google
        et les moteurs IA, c'est quatre compétences, une livraison. Je les
        combine au quotidien.
      </p>
    </div>

    <ul
      class="grid grid-cols-1 md:grid-cols-2 gap-5"
      role="list"
    >
      {services.map((s) => {
        const Icon = s.icon;
        return (
          <li>
            <a
              href={`/services#${s.slug}`}
              class="group glass-card block p-6 h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-400"
            >
              <div class="flex items-start gap-4">
                <div
                  class="shrink-0 flex items-center justify-center h-12 w-12 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/20"
                  aria-hidden="true"
                >
                  <Icon size={22} />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="text-xl font-bold text-slate-100">{s.title}</h3>
                    <ArrowRight
                      size={18}
                      className="text-slate-500 group-hover:text-primary-400 group-hover:translate-x-1 transition-all"
                    />
                  </div>
                  <p class="text-sm text-primary-400/80 font-medium mt-0.5">
                    {s.tagline}
                  </p>
                  <p class="mt-3 text-sm text-slate-400 leading-relaxed">
                    {s.description}
                  </p>
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>
