---
import BaseLayout from '../layouts/BaseLayout.astro';
import { personalInfo } from '../data/portfolioData';
import { Mail, Phone, MapPin, Linkedin, Github, Twitter } from 'lucide-react';
---

<BaseLayout
  pageType="ContactPage"
  title="Contact | Rodrigue GBADOU, freelance SEO/GEO & Automatisation à Paris"
  description="Contactez Rodrigue GBADOU pour un projet SEO/GEO, d'automatisation n8n, d'IA ou de développement web. Réponse sous 24 h. Email, LinkedIn, téléphone."
>
  <section class="pt-32 pb-10 md:pt-40 md:pb-16">
    <div class="container-custom max-w-4xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-400 mb-3">
        Contact
      </p>
      <h1 class="text-4xl md:text-6xl font-bold text-slate-100 leading-tight mb-6">
        Parlons de <span class="gradient-text">votre projet</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-300 leading-relaxed">
        SEO/GEO, automatisation, IA, développement web : racontez-moi votre
        contexte en quelques lignes. Je reviens vers vous sous 24 h ouvrées avec
        un premier avis honnête et des pistes concrètes, sans argumentaire de
        vente.
      </p>
    </div>
  </section>

  <section class="py-12" aria-labelledby="contact-methods-title">
    <div class="container-custom grid md:grid-cols-12 gap-10">
      <aside class="md:col-span-5">
        <h2 id="contact-methods-title" class="sr-only">Moyens de contact</h2>

        <ul class="space-y-4">
          <li>
            <a
              href={`mailto:${personalInfo.email}`}
              class="glass-card flex items-start gap-4 p-5 hover:border-primary-500/40"
            >
              <div
                class="shrink-0 flex items-center justify-center h-11 w-11 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/20"
                aria-hidden="true"
              >
                <Mail size={20} />
              </div>
              <div class="min-w-0">
                <p class="text-xs text-slate-500 uppercase tracking-wider">Email</p>
                <p class="text-sm text-slate-200 font-semibold break-all">
                  {personalInfo.email}
                </p>
                <p class="text-xs text-slate-500 mt-0.5">Privilégié pour les briefs détaillés</p>
              </div>
            </a>
          </li>

          <li>
            <a
              href={`tel:${personalInfo.phone.replace(/\s/g, '')}`}
              class="glass-card flex items-start gap-4 p-5 hover:border-primary-500/40"
            >
              <div
                class="shrink-0 flex items-center justify-center h-11 w-11 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/20"
                aria-hidden="true"
              >
                <Phone size={20} />
              </div>
              <div>
                <p class="text-xs text-slate-500 uppercase tracking-wider">Téléphone</p>
                <p class="text-sm text-slate-200 font-semibold">{personalInfo.phone}</p>
                <p class="text-xs text-slate-500 mt-0.5">Lun-Ven · 9 h - 18 h</p>
              </div>
            </a>
          </li>

          <li>
            <a
              href={personalInfo.socialLinks.linkedin}
              target="_blank"
              rel="noopener noreferrer me"
              class="glass-card flex items-start gap-4 p-5 hover:border-primary-500/40"
            >
              <div
                class="shrink-0 flex items-center justify-center h-11 w-11 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/20"
                aria-hidden="true"
              >
                <Linkedin size={20} />
              </div>
              <div>
                <p class="text-xs text-slate-500 uppercase tracking-wider">LinkedIn</p>
                <p class="text-sm text-slate-200 font-semibold">
                  linkedin.com/in/rodrigue-gbadou
                </p>
                <p class="text-xs text-slate-500 mt-0.5">Pour les propositions CDI / missions</p>
              </div>
            </a>
          </li>

          <li class="glass-card flex items-start gap-4 p-5">
            <div
              class="shrink-0 flex items-center justify-center h-11 w-11 rounded-xl bg-primary-500/10 text-primary-400 border border-primary-500/20"
              aria-hidden="true"
            >
              <MapPin size={20} />
            </div>
            <div>
              <p class="text-xs text-slate-500 uppercase tracking-wider">Localisation</p>
              <p class="text-sm text-slate-200 font-semibold">{personalInfo.location}</p>
              <p class="text-xs text-slate-500 mt-0.5">Disponible en remote &amp; sur site Île-de-France</p>
            </div>
          </li>
        </ul>

        <div class="mt-6 flex gap-3">
          <a
            href={personalInfo.socialLinks.github}
            target="_blank"
            rel="noopener noreferrer me"
            class="btn btn-outline text-xs px-3 py-2"
            aria-label="GitHub"
          >
            <Github size={14} />
            <span>GitHub</span>
          </a>
          <a
            href={personalInfo.socialLinks.twitter}
            target="_blank"
            rel="noopener noreferrer me"
            class="btn btn-outline text-xs px-3 py-2"
            aria-label="Twitter / X"
          >
            <Twitter size={14} />
            <span>Twitter / X</span>
          </a>
        </div>
      </aside>

      <div class="md:col-span-7">
        <div class="glass-card p-6 md:p-8">
          <h2 class="text-xl font-bold text-slate-100 mb-1">Formulaire rapide</h2>
          <p class="text-sm text-slate-400 mb-6">
            Les champs marqués d'un * sont obligatoires. Votre message est
            envoyé par email sans stockage tiers.
          </p>

          <form
            action={`mailto:${personalInfo.email}`}
            method="POST"
            enctype="text/plain"
            class="space-y-5"
          >
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-xs font-semibold text-slate-300 mb-2">
                  Nom *
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  class="w-full rounded-lg bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:border-primary-500"
                  placeholder="Prénom Nom"
                />
              </div>
              <div>
                <label for="email" class="block text-xs font-semibold text-slate-300 mb-2">
                  Email *
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  class="w-full rounded-lg bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:border-primary-500"
                  placeholder="vous@exemple.com"
                />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-xs font-semibold text-slate-300 mb-2">
                Sujet
              </label>
              <select
                id="subject"
                name="subject"
                class="w-full rounded-lg bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-slate-100 focus:outline-none focus:border-primary-500"
              >
                <option>Projet SEO/GEO</option>
                <option>Projet d'automatisation / n8n</option>
                <option>Projet IA / LLM</option>
                <option>Projet de développement web</option>
                <option>Opportunité CDI</option>
                <option>Autre</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs font-semibold text-slate-300 mb-2">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                required
                class="w-full rounded-lg bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-slate-100 placeholder:text-slate-500 focus:outline-none focus:border-primary-500"
                placeholder="Décrivez votre contexte, vos enjeux et ce que vous cherchez..."
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-full sm:w-auto">
              Envoyer le message
            </button>
            <p class="text-xs text-slate-500">
              En envoyant ce formulaire, vous acceptez le traitement de vos
              données conformément à la <a href="/privacy" class="text-primary-400 hover:underline">politique de confidentialité</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
