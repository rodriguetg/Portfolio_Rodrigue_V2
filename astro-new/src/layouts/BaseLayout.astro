---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SchemaOrg from '../components/seo/SchemaOrg.astro';
import CookieBanner from '../components/react/CookieBanner.tsx';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'Article' | 'CollectionPage';
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-image.png',
  canonical,
  pageType = 'WebPage',
  noindex = false,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://rodespe.com';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? site).toString();
const imageURL = image.startsWith('http') ? image : new URL(image, Astro.site ?? site).toString();
---

<!doctype html>
<html lang="fr" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large" />
    )}

    <!-- llms.txt reference for AI crawlers -->
    <link rel="llms" href="/llms.txt" />

    <!-- Open Graph -->
    <meta property="og:type" content={pageType === 'Article' ? 'article' : 'website'} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Rodrigue GBADOU" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
    <meta name="twitter:creator" content="@EsperantRodrigu" />

    <!-- Preconnects -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Theme color -->
    <meta name="theme-color" content="#020617" />

    <!-- Flash of white prevention: apply saved theme before paint -->
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (t === 'light' || (!t && !prefersDark)) {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>

    <SchemaOrg
      pageType={pageType}
      pageTitle={title}
      pageDescription={description}
      pageUrl={canonicalURL}
      imageUrl={imageURL}
    />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-slate-900 focus:text-primary-300 focus:px-4 focus:py-2 focus:rounded-md focus:border focus:border-primary-500"
    >
      Aller au contenu principal
    </a>

    <Header />

    <main id="main-content" class="relative">
      <slot />
    </main>

    <Footer />

    <CookieBanner client:idle />
  </body>
</html>
