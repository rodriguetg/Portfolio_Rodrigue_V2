---
import { caseStudies } from '../../data/caseStudies';
import { ArrowRight } from 'lucide-react';

const preview = caseStudies.slice(0, 2);
---

<section
  id="case-studies-preview"
  class="py-20 md:py-28 bg-slate-950"
  aria-labelledby="case-studies-preview-title"
>
  <div class="container-custom">
    <div class="flex items-end justify-between gap-4 mb-10 flex-wrap">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-primary-400 mb-3">
          Cas concrets
        </p>
        <h2
          id="case-studies-preview-title"
          class="text-3xl md:text-4xl font-bold text-slate-100"
        >
          Études de cas récentes
        </h2>
      </div>
      <a
        href="/case-studies"
        class="inline-flex items-center gap-1.5 text-primary-400 hover:text-primary-300 text-sm font-medium"
      >
        <span>Voir toutes les études</span>
        <ArrowRight size={16} />
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {preview.map((cs) => (
        <article class="glass-card p-6 flex flex-col">
          <img
            src={cs.image}
            alt={`Illustration du projet ${cs.title}`}
            loading="lazy"
            decoding="async"
            width="640"
            height="360"
            class="rounded-xl mb-5 aspect-video w-full object-cover border border-slate-800"
          />
          <h3 class="text-xl font-bold text-slate-100 mb-1.5">{cs.title}</h3>
          <p class="text-sm text-primary-400 mb-3 font-medium">{cs.subtitle}</p>
          <p class="text-sm text-slate-400 leading-relaxed mb-5 flex-1">
            {cs.excerpt}
          </p>
          <div class="flex flex-wrap gap-1.5 mb-5">
            {cs.technologies.slice(0, 4).map((t) => (
              <span class="text-[11px] px-2 py-1 rounded-full bg-slate-800 text-slate-300 border border-slate-700">
                {t}
              </span>
            ))}
          </div>
          <a
            href={`/case-studies/${cs.id}`}
            class="mt-auto inline-flex items-center gap-1.5 text-primary-400 hover:text-primary-300 text-sm font-medium"
          >
            <span>Lire l'étude de cas</span>
            <ArrowRight size={14} />
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
