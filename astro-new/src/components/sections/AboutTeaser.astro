---
import { aboutText, personalInfo } from '../../data/portfolioData';
import { ArrowRight } from 'lucide-react';

const firstParagraph = aboutText.split('\n\n')[0];
---

<section
  id="about-teaser"
  class="py-20 md:py-28"
  aria-labelledby="about-teaser-title"
>
  <div class="container-custom grid md:grid-cols-12 gap-12 items-center">
    <div class="md:col-span-5">
      <div class="relative aspect-[4/5] max-w-sm mx-auto md:mx-0 rounded-3xl overflow-hidden glass-card">
        <img
          src="/rodrigue-gbadou.webp"
          alt={`${personalInfo.name} | portrait professionnel`}
          width="400"
          height="500"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
    <div class="md:col-span-7">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-400 mb-3">
        À propos
      </p>
      <h2
        id="about-teaser-title"
        class="text-3xl md:text-4xl font-bold text-slate-100 mb-5"
      >
        Un profil hybride, au croisement du marketing et du code
      </h2>
      <p class="text-base md:text-lg text-slate-300 leading-relaxed mb-6">
        {firstParagraph}
      </p>
      <ul class="space-y-3 text-sm text-slate-400 mb-8">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-primary-500 shrink-0" aria-hidden="true"></span>
          <span><strong class="text-slate-200">Master Brand Content &amp; Management</strong> à Paris École de Management (PEM)</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-primary-500 shrink-0" aria-hidden="true"></span>
          <span><strong class="text-slate-200">Alternance chez Primelis</strong>, agence SEO de référence en France</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-primary-500 shrink-0" aria-hidden="true"></span>
          <span><strong class="text-slate-200">n8n Certified Creator</strong> avec 9+ workflows publics</span>
        </li>
      </ul>
      <a href="/about" class="btn btn-outline group">
        <span>En savoir plus</span>
        <ArrowRight size={18} className="transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </div>
</section>
